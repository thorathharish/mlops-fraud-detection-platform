FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn mlflow xgboost pandas prometheus-client prometheus-fastapi-instrumentator pydantic

COPY src/serve/ ./src/serve/

ENV MLFLOW_TRACKING_URI=http://mlflow:5000
ENV MODEL_NAME=fraudguard-xgboost
ENV MODEL_STAGE=Production

EXPOSE 8000

CMD ["uvicorn", "src.serve.app:app", "--host", "0.0.0.0", "--port", "8000"]
